# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Anthropic API key (for Claude Agent SDK)
ANTHROPIC_API_KEY=

# Comma-separated Discord user IDs allowed to message the bot (empty = allow all)
DISCORD_ALLOWED_USERS=

# Shared secret for HTTP API Bearer token auth (empty = no auth)
CLAUDECORD_API_SECRET=

# Discord server (guild) ID — enables channel manager (creates/archives agent channels)
DISCORD_GUILD_ID=

# Discord channel ID for #code-status — used for spawn/completion summaries
DISCORD_CODE_STATUS_CHANNEL_ID=

# Discord channel ID for the persistent status board embed (auto-updates every 60s)
DISCORD_STATUS_CHANNEL_ID=

# Optional: daemon HTTP port (default: 19532)
# CLAUDECORD_PORT=19532

# Optional: path to routing config (default: config/routing.json)
# ROUTING_CONFIG=config/routing.json

# Optional: path to tasks file for /tasks slash command
# TASKS_PATH=memory/tasks.md
