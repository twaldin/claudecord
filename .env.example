# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Port for the daemon HTTP API (agents poll this)
CLAUDECORD_PORT=19532

# Optional: override the routing config path
# ROUTING_CONFIG=/path/to/config/routing.json

# Optional: override the daemon URL for shim connections
# CLAUDECORD_DAEMON_URL=http://localhost:19532

# Optional: shared secret for HTTP API authentication.
# If set, all agent-to-daemon requests must include Authorization: Bearer <secret>.
# Set the same value in each agent's .mcp.json env block.
# CLAUDECORD_API_SECRET=

# Optional: comma-separated Discord user IDs allowed to message the bot.
# If not set, all users can message the bot (not recommended for personal use).
# Find your user ID: Discord → Settings → Advanced → Developer Mode → right-click your name → Copy ID
# DISCORD_ALLOWED_USERS=123456789012345678,987654321098765432
