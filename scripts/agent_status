#!/bin/bash
# agent_status — Get context window usage and status for teammates
#
# Usage:
#   agent_status              # All agents
#   agent_status <name>       # Specific agent
#
# Reads the Claude Code status line from each agent's tmux pane.
# The status line typically shows: model, context %, token count, cost.

SESSION="claudecord"
REGISTRY="$HOME/claudecord/registry.tsv"

TARGET="$1"

if [ ! -f "$REGISTRY" ]; then
  echo "ERROR: No registry at $REGISTRY"
  exit 1
fi

echo "=== Agent Status ==="
echo ""
printf "%-15s %-8s %-10s %s\n" "NAME" "WIN.PANE" "ALIVE" "STATUS LINE"
printf "%-15s %-8s %-10s %s\n" "----" "--------" "-----" "-----------"

while IFS='|' read -r name win pane status dir spawned; do
  [[ "$name" == \#* ]] && continue
  [ -z "$name" ] && continue
  [ -n "$TARGET" ] && [ "$name" != "$TARGET" ] && continue

  # Check liveness
  ALIVE="no"
  STATUS_LINE="(pane gone)"
  if tmux list-panes -t "$SESSION:$win" -F '#{pane_index}' 2>/dev/null | grep -q "^$pane$"; then
    ALIVE="yes"
    # Capture the last 5 lines — status line is usually at the bottom
    BOTTOM=$(tmux capture-pane -t "$SESSION:$win.$pane" -p -S -5 2>/dev/null)
    # Look for context/token indicators in the bottom lines
    # Claude Code status shows things like: "Opus · 45% ctx · 120k tokens · $0.52"
    STATUS_LINE=$(echo "$BOTTOM" | grep -iE '(ctx|context|token|opus|sonnet|haiku|%|cost)' | tail -1)
    if [ -z "$STATUS_LINE" ]; then
      # Fallback: just show last non-empty line
      STATUS_LINE=$(echo "$BOTTOM" | grep -v '^$' | tail -1)
    fi
    # Truncate for display
    STATUS_LINE=$(echo "$STATUS_LINE" | cut -c1-80)
  fi

  printf "%-15s %-8s %-10s %s\n" "$name" "$win.$pane" "$ALIVE" "$STATUS_LINE"
done < "$REGISTRY"
