#!/bin/bash
# capture_pane — Capture recent output from a teammate's tmux window
#
# Usage:
#   capture_pane <name>            # Last 50 lines (default)
#   capture_pane <name> <lines>    # Last N lines
#   capture_pane <name> all        # Full scrollback

SESSION="${CLAUDECORD_SESSION:-claudecord}"
CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
REGISTRY="$CLAUDECORD_HOME/registry.tsv"

NAME="$1"
LINES="${2:-50}"

if [ -z "$NAME" ]; then
  echo "Usage: capture_pane <name> [lines|all]"
  exit 1
fi

if [ ! -f "$REGISTRY" ]; then
  echo "ERROR: No registry at $REGISTRY"
  exit 1
fi

# Verify agent is registered
ENTRY=$(grep "^$NAME|" "$REGISTRY" | tail -1)
if [ -z "$ENTRY" ]; then
  echo "ERROR: Agent '$NAME' not found in registry"
  exit 1
fi

# Check window exists
if ! tmux list-windows -t "$SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^$NAME$"; then
  echo "ERROR: Window '$NAME' no longer exists (agent dead)"
  exit 1
fi

if [ "$LINES" = "all" ]; then
  tmux capture-pane -t "$SESSION:$NAME" -p -S -
else
  tmux capture-pane -t "$SESSION:$NAME" -p -S "-$LINES"
fi
