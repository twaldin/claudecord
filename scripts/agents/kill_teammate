#!/bin/bash
# kill_teammate — Stop a teammate agent
# Usage: kill_teammate <name>

set -e

sed_inplace() { if [[ "$OSTYPE" == "darwin"* ]]; then sed -i '' "$@"; else sed -i "$@"; fi; }

# Source .env for API secret
CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
if [ -f "$CLAUDECORD_HOME/.env" ]; then
  set -a; source "$CLAUDECORD_HOME/.env"; set +a
fi

NAME="$1"
SESSION="${CLAUDECORD_SESSION:-claudecord}"
REGISTRY="$CLAUDECORD_HOME/registry.tsv"

if [ -z "$NAME" ]; then
  echo "Usage: kill_teammate <name>"
  exit 1
fi

if [ "$NAME" = "orchestrator" ]; then
  echo "ERROR: Cannot kill the orchestrator. Use 'tmux kill-session -t $SESSION' to shut everything down."
  exit 1
fi

ENTRY=$(grep "^$NAME|alive|" "$REGISTRY" 2>/dev/null | tail -1)
if [ -z "$ENTRY" ]; then
  echo "ERROR: teammate '$NAME' not found or not alive"
  exit 1
fi

DAEMON_URL="${CLAUDECORD_DAEMON_URL:-http://localhost:19532}"
curl -sf -X POST "$DAEMON_URL/agent/died" \
  -H "Content-Type: application/json" \
  ${CLAUDECORD_API_SECRET:+-H "Authorization: Bearer $CLAUDECORD_API_SECRET"} \
  -d "{\"agentName\":\"$NAME\"}" \
  >/dev/null 2>&1 || true

# Kill the window
tmux kill-window -t "$SESSION:$NAME" 2>/dev/null || true

# Mark dead in registry
sed_inplace "s/^$NAME|alive|/$NAME|dead|/" "$REGISTRY"

echo "Killed $NAME"
