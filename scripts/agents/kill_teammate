#!/bin/bash
# kill_teammate — Stop a teammate agent
# Usage: kill_teammate <name>

set -e

# Source .env for API secret
CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
if [ -f "$CLAUDECORD_HOME/.env" ]; then
  set -a; source "$CLAUDECORD_HOME/.env"; set +a
fi

NAME="$1"
SESSION="claudecord"
REGISTRY="$CLAUDECORD_HOME/registry.tsv"

if [ -z "$NAME" ]; then
  echo "Usage: kill_teammate <name>"
  exit 1
fi

if [ "$NAME" = "lifeos" ]; then
  echo "ERROR: Cannot kill LifeOS (the manager). Use 'tmux kill-session -t claudecord' to shut everything down."
  exit 1
fi

ENTRY=$(grep "^$NAME|.*|alive" "$REGISTRY" 2>/dev/null | tail -1)
if [ -z "$ENTRY" ]; then
  echo "ERROR: teammate '$NAME' not found or not alive"
  exit 1
fi

# Registry format: name|window|pane|status|dir|spawned
WINDOW=$(echo "$ENTRY" | cut -d'|' -f2)
PANE_INDEX=$(echo "$ENTRY" | cut -d'|' -f3)

DAEMON_URL="${CLAUDECORD_DAEMON_URL:-http://localhost:19532}"
curl -sf -X POST "$DAEMON_URL/agent/died" \
  -H "Content-Type: application/json" \
  ${CLAUDECORD_API_SECRET:+-H "Authorization: Bearer $CLAUDECORD_API_SECRET"} \
  -d "{\"agentName\":\"$NAME\"}" \
  >/dev/null 2>&1 || true

# Kill the pane
tmux kill-pane -t "$SESSION:$WINDOW.$PANE_INDEX" 2>/dev/null || true

# Mark dead in registry
if [[ "$OSTYPE" == "darwin"* ]]; then
  sed -i '' "s/^$NAME|$WINDOW|$PANE_INDEX|alive/$NAME|$WINDOW|$PANE_INDEX|dead/" "$REGISTRY"
else
  sed -i "s/^$NAME|$WINDOW|$PANE_INDEX|alive/$NAME|$WINDOW|$PANE_INDEX|dead/" "$REGISTRY"
fi

echo "Killed $NAME (was pane $WINDOW.$PANE_INDEX)"
