#!/bin/bash
# kill_teammate — Stop a teammate agent
# Usage: kill_teammate <name>

set -e

# Source .env for API secret
CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
if [ -f "$CLAUDECORD_HOME/.env" ]; then
  set -a; source "$CLAUDECORD_HOME/.env"; set +a
fi

NAME="$1"
SESSION="claudecord"

if [ -z "$NAME" ]; then
  echo "Usage: kill_teammate <name>"
  exit 1
fi

if [ "$NAME" = "lifeos" ]; then
  echo "ERROR: Cannot kill LifeOS (the manager). Use 'tmux kill-session -t claudecord' to shut everything down."
  exit 1
fi

DAEMON_URL="${CLAUDECORD_DAEMON_URL:-http://localhost:19532}"
DIED_RESPONSE=$(curl -sf -X POST "$DAEMON_URL/agent/died" \
  -H "Content-Type: application/json" \
  ${CLAUDECORD_API_SECRET:+-H "Authorization: Bearer $CLAUDECORD_API_SECRET"} \
  -d "{\"agentName\":\"$NAME\"}" \
  2>/dev/null || echo '{}')

# Check for 404 (not found in registry) — still kill the window if it exists
if echo "$DIED_RESPONSE" | grep -q '"error"'; then
  echo "WARNING: daemon reported error for $NAME — proceeding with tmux kill anyway"
fi

# Clean up injected .mcp.json before killing the window
# Read the env vars spawn_teammate set for this agent
MCP_BACKUP=$(tmux show-environment -t "$SESSION:$NAME" CLAUDECORD_MCP_BACKUP 2>/dev/null | cut -d= -f2- || true)
MCP_CREATED=$(tmux show-environment -t "$SESSION:$NAME" CLAUDECORD_MCP_CREATED 2>/dev/null | cut -d= -f2- || true)
WORKTREE_DIR=$(tmux show-environment -t "$SESSION:$NAME" CLAUDECORD_WORKTREE 2>/dev/null | cut -d= -f2- || true)

if [ -n "$MCP_CREATED" ] && [ -f "$MCP_CREATED" ]; then
  rm -f "$MCP_CREATED"
  echo "Cleaned up injected .mcp.json"
elif [ -n "$MCP_BACKUP" ] && [ -f "$MCP_BACKUP" ]; then
  MCP_FILE="${MCP_BACKUP%.claudecord-backup}"
  mv "$MCP_BACKUP" "$MCP_FILE"
  echo "Restored original .mcp.json"
fi

# Kill the window
tmux kill-window -t "$SESSION:$NAME" 2>/dev/null || true

# Clean up worktree if one was created
if [ -n "$WORKTREE_DIR" ] && [ -d "$WORKTREE_DIR" ]; then
  git worktree remove "$WORKTREE_DIR" --force 2>/dev/null || rm -rf "$WORKTREE_DIR"
  echo "Cleaned up worktree at $WORKTREE_DIR"
fi

echo "Killed $NAME"
