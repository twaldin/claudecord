#!/bin/bash
# list_teammates — Show status of all registered agents
# Usage: list_teammates

SESSION="${CLAUDECORD_SESSION:-claudecord}"
CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
REGISTRY="$CLAUDECORD_HOME/registry.tsv"

if [ ! -f "$REGISTRY" ]; then
  echo "No registry found at $REGISTRY"
  exit 1
fi

echo "=== Claudecord Agent Team ==="
echo ""
printf "%-15s %-8s %-40s %s\n" "NAME" "STATUS" "DIRECTORY" "SPAWNED"
printf "%-15s %-8s %-40s %s\n" "----" "------" "---------" "-------"

while IFS='|' read -r name status dir spawned; do
  # Skip header
  [[ "$name" == \#* ]] && continue
  [ -z "$name" ] && continue

  # Check if window is actually alive
  ACTUAL_STATUS="$status"
  if [ "$status" = "alive" ]; then
    if ! tmux list-windows -t "$SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^$name$"; then
      ACTUAL_STATUS="DEAD"
    else
      # Check if claude is actually running in this window
      PANE_PID=$(tmux display-message -t "$SESSION:$name" -p '#{pane_pid}' 2>/dev/null)
      if [ -n "$PANE_PID" ] && ! pgrep -P "$PANE_PID" -f "claude" >/dev/null 2>&1; then
        ACTUAL_STATUS="EXITED"
      fi
    fi
  fi

  printf "%-15s %-8s %-40s %s\n" "$name" "$ACTUAL_STATUS" "$dir" "$spawned"
done < "$REGISTRY"

echo ""
echo "Total windows: $(tmux list-windows -t "$SESSION" 2>/dev/null | wc -l | tr -d ' ')"
