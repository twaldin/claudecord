#!/bin/bash
# message_orchestrator — Send a message to the orchestrator agent
# Usage: message_orchestrator <message>
# Example: message_orchestrator "Coder finished PR #42 — please review"
#
# The orchestrator runs in pane 0 of the claudecord tmux session.
# This script injects a message directly via tmux send-keys.

set -e

MESSAGE="$*"

if [ -z "$MESSAGE" ]; then
  echo "Usage: message_orchestrator <message>"
  exit 1
fi

SESSION="${CLAUDECORD_SESSION:-claudecord}"
ORCHESTRATOR_PANE="${CLAUDECORD_ORCHESTRATOR_PANE:-0}"

# Verify session exists
if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "ERROR: tmux session '$SESSION' not found"
  exit 1
fi

# Determine sender name from CLAUDECORD_AGENT_NAME env var, or derive from PWD
SENDER="${CLAUDECORD_AGENT_NAME:-$(basename "$PWD")}"
SENDER_UPPER=$(echo "$SENDER" | tr '[:lower:]' '[:upper:]')

# Send with envelope prefix to prevent prompt injection
ENVELOPE="[$SENDER_UPPER]: $MESSAGE"
tmux send-keys -t "$SESSION:$ORCHESTRATOR_PANE" -l "$ENVELOPE"
sleep 1
tmux send-keys -t "$SESSION:$ORCHESTRATOR_PANE" Enter

echo "Sent to orchestrator"
