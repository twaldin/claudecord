#!/bin/bash
# prune_registry — Remove dead entries from registry, keeping alive + header
# Usage: prune_registry [--dry-run]
#
# Keeps: header line, all alive entries
# Removes: all dead entries

CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
REGISTRY="$CLAUDECORD_HOME/registry.tsv"
DRY_RUN="${1:-}"

if [ ! -f "$REGISTRY" ]; then
  echo "No registry at $REGISTRY"
  exit 1
fi

TOTAL=$(grep -c '|dead|' "$REGISTRY" 2>/dev/null || echo 0)
ALIVE=$(grep -c '|alive|' "$REGISTRY" 2>/dev/null || echo 0)

if [ "$TOTAL" -eq 0 ]; then
  echo "Registry clean — no dead entries to prune."
  exit 0
fi

echo "Registry: $ALIVE alive, $TOTAL dead"

if [ "$DRY_RUN" = "--dry-run" ]; then
  echo "Would remove $TOTAL dead entries. Run without --dry-run to execute."
  exit 0
fi

# Keep header + alive entries
grep -v '|dead|' "$REGISTRY" > "${REGISTRY}.tmp"
mv "${REGISTRY}.tmp" "$REGISTRY"

echo "Pruned $TOTAL dead entries. $ALIVE alive entries remain."
