#!/bin/bash
# spawn_teammate — Spawn a new Claude Code agent in a named tmux window
#
# Usage:
#   spawn_teammate <name> <directory> [--model opus|sonnet|haiku] [--lifecycle persistent|scheduled|ephemeral]
#   spawn_teammate <name> --project <project_dir> [--model opus|sonnet|haiku]
#
# Agent dir mode: launches claude in the given directory with its own CLAUDE.md + .mcp.json
# Worktree mode:  launches `claude --worktree` from the project dir — inherits skills, CLAUDE.md, settings
# --model:        select model tier (default: sonnet)
#                 opus   — complex reasoning, specs, planning, trading analysis
#                 sonnet — code implementation, reviews, monitoring (default)
#                 haiku  — simple tasks, price fetching, cron work
# --lifecycle:    persistent | scheduled | ephemeral (default: ephemeral)

set -e

# Source .env for API secret (needed for daemon curl calls)
CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
if [ -f "$CLAUDECORD_HOME/.env" ]; then
  set -a; source "$CLAUDECORD_HOME/.env"; set +a
fi

NAME="$1"
SESSION="${CLAUDECORD_SESSION:-claudecord}"
MODEL="sonnet"  # default
LIFECYCLE="ephemeral"  # default

# Parse args
shift
MODE="agent"
DIR=""
TASK_DESC=""
AGENT_TYPE="coder"
while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      MODE="worktree"
      DIR="$2"
      shift 2
      ;;
    --model)
      MODEL="$2"
      shift 2
      ;;
    --task)
      TASK_DESC="$2"
      shift 2
      ;;
    --lifecycle)
      LIFECYCLE="$2"
      shift 2
      ;;
    --type)
      AGENT_TYPE="$2"
      shift 2
      ;;
    *)
      if [ -z "$DIR" ]; then
        DIR="$1"
      fi
      shift
      ;;
  esac
done

if [ -z "$NAME" ] || [ -z "$DIR" ]; then
  echo "Usage: spawn_teammate <name> <directory> [--model opus|sonnet|haiku] [--lifecycle persistent|scheduled|ephemeral]"
  echo "       spawn_teammate <name> --project <project_dir> [--model opus|sonnet|haiku]"
  echo ""
  echo "Models: opus (complex), sonnet (default), haiku (simple)"
  echo "Lifecycles: ephemeral (default), persistent, scheduled"
  exit 1
fi

# Ensure directory exists
if [ ! -d "$DIR" ]; then
  echo "ERROR: directory $DIR does not exist"
  exit 1
fi

# Ensure tmux session exists
if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "ERROR: tmux session '$SESSION' does not exist. Run start.sh first."
  exit 1
fi

# Build the claude command based on mode + model
MODEL_FLAG="--model $MODEL"
if [ "$MODE" = "worktree" ]; then
  CLAUDE_CMD="claude --worktree --dangerously-load-development-channels server:claudecord --dangerously-skip-permissions $MODEL_FLAG"
else
  CLAUDE_CMD="claude --dangerously-load-development-channels server:claudecord --dangerously-skip-permissions $MODEL_FLAG"
fi

# Create new named window — each agent gets its own window
tmux new-window -t "$SESSION" -n "$NAME" -c "$DIR" \
  "export CLAUDECORD_AGENT_NAME='$NAME'; export PATH=\"$CLAUDECORD_HOME/scripts/agents:$CLAUDECORD_HOME/scripts/tools:\$PATH\"; $CLAUDE_CMD 2>&1; echo '[AGENT $NAME EXITED]'; read"

# Auto-confirm prompts (dev channels or worktree)
sleep 3
tmux send-keys -t "$SESSION:$NAME" Enter

# Send task as first prompt if provided
if [ -n "$TASK_DESC" ]; then
  sleep 2
  tmux send-keys -t "$SESSION:$NAME" "$TASK_DESC" Enter
fi

# Register with daemon
DAEMON_URL="${CLAUDECORD_DAEMON_URL:-http://localhost:19532}"
SPAWN_RESPONSE=$(curl -sf -X POST "$DAEMON_URL/agent/spawn" \
  -H "Content-Type: application/json" \
  ${CLAUDECORD_API_SECRET:+-H "Authorization: Bearer $CLAUDECORD_API_SECRET"} \
  -d "{\"agentName\":\"$NAME\",\"agentType\":\"$AGENT_TYPE\",\"lifecycle\":\"$LIFECYCLE\",\"task\":\"${TASK_DESC:-spawned}\",\"directory\":\"$DIR\",\"model\":\"$MODEL\"}" \
  2>/dev/null || echo '{"ok":false}')

CHANNEL_ID=""
if command -v jq >/dev/null 2>&1; then
  CHANNEL_ID=$(echo "$SPAWN_RESPONSE" | jq -r '.channelId // ""' 2>/dev/null || true)
fi

if [ -n "$CHANNEL_ID" ] && [ "$CHANNEL_ID" != "null" ] && [ "$CHANNEL_ID" != "" ]; then
  echo "Spawned $NAME ($LIFECYCLE, $MODEL) at $DIR — channel: $CHANNEL_ID"
else
  echo "Spawned $NAME ($LIFECYCLE, $MODEL) at $DIR"
  if echo "$SPAWN_RESPONSE" | grep -q '"ok":false'; then
    echo "WARNING: daemon unreachable — agent spawned without channel"
  fi
fi
