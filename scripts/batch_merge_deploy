#!/bin/bash
# batch_merge_deploy — Merge approved PRs and deploy to VPS
#
# Usage: batch_merge_deploy [pr_numbers...]
#        batch_merge_deploy --approved    (merge all approved PRs)
#
# Merges PRs to main, pulls on VPS, runs npm install + vite build + pm2 restart.

set -e

REPO_DIR="$HOME/trade-up-bot"
VPS="root@178.156.239.58"
VPS_DIR="/root/trade-up-bot"
PR_LIST=()

cd "$REPO_DIR"

if [ "$1" = "--approved" ]; then
  # Find all approved PRs
  mapfile -t PR_LIST < <(gh pr list --json number,reviewDecision -q '.[] | select(.reviewDecision == "APPROVED") | .number')
  if [ ${#PR_LIST[@]} -eq 0 ]; then
    echo "No approved PRs found."
    exit 0
  fi
  echo "Found ${#PR_LIST[@]} approved PRs: ${PR_LIST[*]}"
else
  PR_LIST=("$@")
fi

if [ ${#PR_LIST[@]} -eq 0 ]; then
  echo "Usage: batch_merge_deploy [pr_numbers...] or --approved"
  exit 1
fi

# Merge each PR
MERGED=()
for PR in "${PR_LIST[@]}"; do
  echo "Merging PR #$PR..."
  if gh pr merge "$PR" --squash --delete-branch 2>/dev/null; then
    MERGED+=("$PR")
    echo "  Merged #$PR"
  else
    echo "  FAILED to merge #$PR — skipping"
  fi
done

if [ ${#MERGED[@]} -eq 0 ]; then
  echo "No PRs were merged. Aborting deploy."
  exit 1
fi

echo ""
echo "Merged ${#MERGED[@]} PRs: ${MERGED[*]}"
echo "Deploying to VPS..."

# Deploy to VPS
ssh -o ConnectTimeout=10 "$VPS" bash -s <<'DEPLOY'
cd /root/trade-up-bot
git pull origin main
npm install
npx vite build 2>/dev/null || true
pm2 restart all
echo "Deploy complete. PM2 status:"
pm2 list
DEPLOY

echo ""
echo "Deploy complete. Merged PRs: ${MERGED[*]}"
