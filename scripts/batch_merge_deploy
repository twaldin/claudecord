#!/bin/bash
# batch_merge_deploy — Merge approved PRs and deploy to a remote server
#
# Usage: batch_merge_deploy [pr_numbers...]
#        batch_merge_deploy --approved    (merge all approved PRs)
#
# Merges PRs to main, then runs the configured deploy command.
#
# Required env vars (set in .env):
#   DEPLOY_REPO_DIR   — local path to the project repo
#   DEPLOY_VPS        — SSH target (e.g. user@host)
#   DEPLOY_VPS_DIR    — remote directory to deploy to
#   DEPLOY_RESTART    — command to restart the service (e.g. "pm2 restart all")

set -e

REPO_DIR="${DEPLOY_REPO_DIR:-}"
VPS="${DEPLOY_VPS:-}"
VPS_DIR="${DEPLOY_VPS_DIR:-}"
RESTART_CMD="${DEPLOY_RESTART:-pm2 restart all}"
PR_LIST=()

if [ -z "$REPO_DIR" ]; then
  echo "ERROR: DEPLOY_REPO_DIR not set (add to .env)"
  exit 1
fi

if [ -z "$VPS" ] || [ -z "$VPS_DIR" ]; then
  echo "ERROR: DEPLOY_VPS and DEPLOY_VPS_DIR must be set in .env"
  exit 1
fi

cd "$REPO_DIR"

if [ "$1" = "--approved" ]; then
  # Find all approved PRs
  mapfile -t PR_LIST < <(gh pr list --json number,reviewDecision -q '.[] | select(.reviewDecision == "APPROVED") | .number')
  if [ ${#PR_LIST[@]} -eq 0 ]; then
    echo "No approved PRs found."
    exit 0
  fi
  echo "Found ${#PR_LIST[@]} approved PRs: ${PR_LIST[*]}"
else
  PR_LIST=("$@")
fi

if [ ${#PR_LIST[@]} -eq 0 ]; then
  echo "Usage: batch_merge_deploy [pr_numbers...] or --approved"
  exit 1
fi

# Merge each PR
MERGED=()
for PR in "${PR_LIST[@]}"; do
  echo "Merging PR #$PR..."
  if gh pr merge "$PR" --squash --delete-branch 2>/dev/null; then
    MERGED+=("$PR")
    echo "  Merged #$PR"
  else
    echo "  FAILED to merge #$PR — skipping"
  fi
done

if [ ${#MERGED[@]} -eq 0 ]; then
  echo "No PRs were merged. Aborting deploy."
  exit 1
fi

echo ""
echo "Merged ${#MERGED[@]} PRs: ${MERGED[*]}"
echo "Deploying to $VPS..."

# Deploy to remote server
ssh -o ConnectTimeout=10 "$VPS" "cd $VPS_DIR && git pull origin main && npm install && $RESTART_CMD"

echo ""
echo "Deploy complete. Merged PRs: ${MERGED[*]}"
