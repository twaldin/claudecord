#!/bin/bash
# kill_teammate — Stop a teammate agent
# Usage: kill_teammate <name>

set -e

# Source .env for API secret
CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
if [ -f "$CLAUDECORD_HOME/.env" ]; then
  set -a; source "$CLAUDECORD_HOME/.env"; set +a
fi

NAME="$1"
SESSION="claudecord"

if [ -z "$NAME" ]; then
  echo "Usage: kill_teammate <name>"
  exit 1
fi

if [ "$NAME" = "lifeos" ]; then
  echo "ERROR: Cannot kill LifeOS (the manager). Use 'tmux kill-session -t claudecord' to shut everything down."
  exit 1
fi

DAEMON_URL="${CLAUDECORD_DAEMON_URL:-http://localhost:19532}"
DIED_RESPONSE=$(curl -sf -X POST "$DAEMON_URL/agent/died" \
  -H "Content-Type: application/json" \
  ${CLAUDECORD_API_SECRET:+-H "Authorization: Bearer $CLAUDECORD_API_SECRET"} \
  -d "{\"agentName\":\"$NAME\"}" \
  2>/dev/null || echo '{}')

# Check for 404 (not found in registry) — still kill the window if it exists
if echo "$DIED_RESPONSE" | grep -q '"error"'; then
  echo "WARNING: daemon reported error for $NAME — proceeding with tmux kill anyway"
fi

# Kill the window
tmux kill-window -t "$SESSION:$NAME" 2>/dev/null || true

echo "Killed $NAME"
