#!/bin/bash
# list_teammates — Show status of all registered agents
# Usage: list_teammates

SESSION="claudecord"
DAEMON_URL="${CLAUDECORD_DAEMON_URL:-http://localhost:19532}"

# Source .env for API secret
CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
if [ -f "$CLAUDECORD_HOME/.env" ]; then
  set -a; source "$CLAUDECORD_HOME/.env"; set +a
fi

daemon_curl() {
  if [ -n "$CLAUDECORD_API_SECRET" ]; then
    curl -sf -H "Authorization: Bearer $CLAUDECORD_API_SECRET" "$@"
  else
    curl -sf "$@"
  fi
}

AGENTS_JSON=$(daemon_curl "$DAEMON_URL/agents" 2>/dev/null)
if [ -z "$AGENTS_JSON" ]; then
  echo "ERROR: daemon unreachable at $DAEMON_URL"
  exit 1
fi

echo "=== Claudecord Agent Team ==="
echo ""
printf "%-20s %-12s %-12s %-8s %-6s %s\n" "NAME" "LIFECYCLE" "STATUS" "ALIVE" "CTX%" "CHANNEL"
printf "%-20s %-12s %-12s %-8s %-6s %s\n" "----" "---------" "------" "-----" "----" "-------"

if command -v jq >/dev/null 2>&1; then
  echo "$AGENTS_JSON" | jq -r '.agents[] | [
    .name,
    (.lifecycle // "?"),
    (.agentStatus // "unknown"),
    .status,
    (if .contextPct == null then "-" else (.contextPct | tostring) + "%" end),
    (.channelId // "-")
  ] | @tsv' | while IFS=$'\t' read -r name lifecycle agent_status status ctx_pct channel_id; do
    # Check tmux liveness for alive agents
    TMUX_STATUS="?"
    if [ "$status" = "alive" ]; then
      if tmux list-windows -t "$SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^$name$"; then
        TMUX_STATUS="yes"
      else
        TMUX_STATUS="no"
      fi
    else
      TMUX_STATUS="-"
    fi
    printf "%-20s %-12s %-12s %-8s %-6s %s\n" "$name" "$lifecycle" "$agent_status" "$TMUX_STATUS" "$ctx_pct" "$channel_id"
  done
else
  echo "WARNING: jq not installed — showing raw JSON"
  echo "$AGENTS_JSON"
fi

echo ""
echo "Total windows: $(tmux list-windows -t "$SESSION" 2>/dev/null | wc -l | tr -d ' ')"
