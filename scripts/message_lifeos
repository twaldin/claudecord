#!/bin/bash
# message_lifeos — Send a message to the LifeOS orchestrator session
# Usage: message_lifeos <message>
# Example: message_lifeos "Pricing anomaly detected: Nova Clear Polymer BS overpriced 19.8x"
#
# LifeOS runs in tmux session "lifeos", not in the claudecord session.
# This script injects a message directly via tmux send-keys.

set -e

MESSAGE="$*"

if [ -z "$MESSAGE" ]; then
  echo "Usage: message_lifeos <message>"
  exit 1
fi

LIFEOS_SESSION="lifeos"
LIFEOS_PANE="1.1"

# Verify lifeos session exists
if ! tmux has-session -t "$LIFEOS_SESSION" 2>/dev/null; then
  echo "ERROR: lifeos tmux session not found"
  exit 1
fi

# Determine sender name from CLAUDECORD_AGENT_NAME env var, or derive from PWD
SENDER="${CLAUDECORD_AGENT_NAME:-$(basename $PWD)}"
SENDER_UPPER=$(echo "$SENDER" | tr '[:lower:]' '[:upper:]')

# Send with envelope prefix
ENVELOPE="[$SENDER_UPPER]: $MESSAGE"
tmux send-keys -t "$LIFEOS_SESSION:$LIFEOS_PANE" -l "$ENVELOPE"
sleep 1
tmux send-keys -t "$LIFEOS_SESSION:$LIFEOS_PANE" Enter

echo "Sent to LifeOS"
