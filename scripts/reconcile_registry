#!/bin/bash
# reconcile_registry — Sync registry with actual tmux state
#
# Run at session boot to find agents that survived compaction
# or detect stale entries that reference dead panes.
#
# Usage: reconcile_registry [--fix]
#   Without --fix: report only (dry run)
#   With --fix: update registry to match reality

SESSION="claudecord"
REGISTRY="$HOME/claudecord/registry.tsv"
FIX="${1:-}"

if [ ! -f "$REGISTRY" ]; then
  echo "No registry at $REGISTRY"
  exit 1
fi

if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "No tmux session '$SESSION'"
  exit 1
fi

echo "=== Registry Reconciliation ==="
echo ""

CHANGES=0

# Check each registry entry against reality
while IFS='|' read -r name win pane status dir spawned; do
  [[ "$name" == \#* ]] && continue
  [ -z "$name" ] && continue

  if [ "$status" = "alive" ]; then
    # Check if pane exists
    if ! tmux list-panes -t "$SESSION:$win" -F '#{pane_index}' 2>/dev/null | grep -q "^$pane$"; then
      echo "STALE: $name registered as alive at $win.$pane but pane is gone"
      if [ "$FIX" = "--fix" ]; then
        sed -i '' "s/^$name|$win|$pane|alive/$name|$win|$pane|dead/" "$REGISTRY"
        echo "  → marked dead"
      fi
      CHANGES=$((CHANGES + 1))
    else
      # Check if claude is running
      PANE_PID=$(tmux display-message -t "$SESSION:$win.$pane" -p '#{pane_pid}' 2>/dev/null)
      if [ -n "$PANE_PID" ] && pgrep -P "$PANE_PID" -f "claude" >/dev/null 2>&1; then
        echo "OK: $name alive at $win.$pane (claude running)"
      else
        echo "EXITED: $name at $win.$pane — pane exists but claude not running"
        CHANGES=$((CHANGES + 1))
      fi
    fi
  fi
done < "$REGISTRY"

# Scan for unregistered claude agents in tmux
echo ""
echo "--- Scanning for unregistered agents ---"
for win in $(tmux list-windows -t "$SESSION" -F '#{window_index}' 2>/dev/null); do
  for pane in $(tmux list-panes -t "$SESSION:$win" -F '#{pane_index}' 2>/dev/null); do
    PANE_PID=$(tmux display-message -t "$SESSION:$win.$pane" -p '#{pane_pid}' 2>/dev/null)
    if [ -n "$PANE_PID" ] && pgrep -P "$PANE_PID" -f "claude" >/dev/null 2>&1; then
      # Check if registered
      if ! grep -q "|$win|$pane|alive" "$REGISTRY" 2>/dev/null; then
        TITLE=$(tmux display-message -t "$SESSION:$win.$pane" -p '#{pane_title}' 2>/dev/null)
        echo "UNREGISTERED: claude running at $win.$pane — title: $TITLE"
        CHANGES=$((CHANGES + 1))
      fi
    fi
  done
done

echo ""
if [ $CHANGES -eq 0 ]; then
  echo "Registry is clean — no discrepancies."
else
  echo "$CHANGES discrepancies found."
  [ "$FIX" != "--fix" ] && echo "Run with --fix to update registry."
fi
