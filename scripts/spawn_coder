#!/bin/bash
# spawn_coder — Spawn a GSD coder agent to fix a GitHub issue
#
# Usage: spawn_coder <issue_number> [--model opus|sonnet|haiku]
#
# Reads the issue from GitHub, creates a worktree, and spawns a coder with
# full context. The coder implements the fix, creates a PR, then exits.
#
# Required env vars:
#   PROJECT_DIR    — local path to the project repo
#   PR_REVIEWER    — GitHub username to assign as reviewer (optional)

set -e

ISSUE="$1"
MODEL="sonnet"
PROJECT_DIR="${PROJECT_DIR:-}"
PR_REVIEWER="${PR_REVIEWER:-}"
CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
SESSION="${CLAUDECORD_SESSION:-claudecord}"

# Parse optional --model flag
shift || true
while [ $# -gt 0 ]; do
  case "$1" in
    --model) MODEL="$2"; shift 2 ;;
    *) shift ;;
  esac
done

if [ -z "$ISSUE" ]; then
  echo "Usage: spawn_coder <issue_number> [--model opus|sonnet|haiku]"
  exit 1
fi

if [ -z "$PROJECT_DIR" ]; then
  echo "ERROR: PROJECT_DIR environment variable not set"
  exit 1
fi

# Fetch issue details
ISSUE_TITLE=$(cd "$PROJECT_DIR" && gh issue view "$ISSUE" --json title -q '.title' 2>/dev/null)
ISSUE_BODY=$(cd "$PROJECT_DIR" && gh issue view "$ISSUE" --json body -q '.body' 2>/dev/null)

if [ -z "$ISSUE_TITLE" ]; then
  echo "ERROR: Could not fetch issue #$ISSUE"
  exit 1
fi

# Create worktree
BRANCH="fix/issue-${ISSUE}"
WT_DIR="/tmp/claudecord-wt-fix-${ISSUE}"

if [ -d "$WT_DIR" ]; then
  echo "Worktree already exists at $WT_DIR — reusing"
else
  cd "$PROJECT_DIR"
  git worktree add "$WT_DIR" -b "$BRANCH" main 2>/dev/null || \
    git worktree add "$WT_DIR" "$BRANCH" 2>/dev/null
fi

# Copy coder template
cp "$CLAUDECORD_HOME/agents/coder/template.md" "$WT_DIR/AGENT.md" 2>/dev/null || true

# Spawn the agent
AGENT_NAME="coder-fix-${ISSUE}"
"$CLAUDECORD_HOME/scripts/spawn_teammate" "$AGENT_NAME" "$WT_DIR" --model "$MODEL"

# Build reviewer instruction
REVIEWER_INSTRUCTION=""
if [ -n "$PR_REVIEWER" ]; then
  REVIEWER_INSTRUCTION="5. Assign $PR_REVIEWER as reviewer on the PR"
fi

# Send task with issue context
sleep 5
"$CLAUDECORD_HOME/scripts/send_message" "$AGENT_NAME" \
  "Fix GitHub issue #${ISSUE}: ${ISSUE_TITLE}

Issue description:
${ISSUE_BODY}

Instructions:
1. Read the issue carefully and understand the problem
2. Implement the fix using GSD workflow (/gsd:fast for small fixes)
3. Run tests to verify
4. Create a PR with 'Fixes #${ISSUE}' in the body
${REVIEWER_INSTRUCTION}
6. Message orchestrator: message_orchestrator 'Fix for issue #${ISSUE} complete. PR created. Summary.'
7. /exit"

echo "Spawned $AGENT_NAME for issue #$ISSUE"
