#!/bin/bash
# spawn_fix_coder — Spawn a GSD coder agent to fix a GitHub issue
#
# Usage: spawn_fix_coder <issue_number> [--model opus|sonnet|haiku]
#
# Reads the issue from GitHub, creates a worktree, and spawns a coder with
# full context. The coder uses the GSD template to implement the fix,
# create a PR referencing the issue, then message_lifeos and exit.

set -e

ISSUE="$1"
MODEL="sonnet"
REPO_DIR="$HOME/trade-up-bot"
SESSION="claudecord"

# Parse optional --model flag
shift || true
while [ $# -gt 0 ]; do
  case "$1" in
    --model) MODEL="$2"; shift 2 ;;
    *) shift ;;
  esac
done

if [ -z "$ISSUE" ]; then
  echo "Usage: spawn_fix_coder <issue_number> [--model opus|sonnet|haiku]"
  exit 1
fi

# Fetch issue details
ISSUE_TITLE=$(cd "$REPO_DIR" && gh issue view "$ISSUE" --json title -q '.title' 2>/dev/null)
ISSUE_BODY=$(cd "$REPO_DIR" && gh issue view "$ISSUE" --json body -q '.body' 2>/dev/null)

if [ -z "$ISSUE_TITLE" ]; then
  echo "ERROR: Could not fetch issue #$ISSUE"
  exit 1
fi

# Create worktree
BRANCH="fix/issue-${ISSUE}"
WT_DIR="/tmp/claudecord-wt-fix-${ISSUE}"

if [ -d "$WT_DIR" ]; then
  echo "Worktree already exists at $WT_DIR — reusing"
else
  cd "$REPO_DIR"
  git worktree add "$WT_DIR" -b "$BRANCH" main 2>/dev/null || \
    git worktree add "$WT_DIR" "$BRANCH" 2>/dev/null
fi

# Copy coder template + symlink message_lifeos so agents can use it
cp "$HOME/claudecord/agents/coder-template-gsd.md" "$WT_DIR/AGENT.md" 2>/dev/null || true
ln -sf "$HOME/claudecord/scripts/message_lifeos" "$WT_DIR/message_lifeos" 2>/dev/null || true

# Spawn the agent
AGENT_NAME="coder-fix-${ISSUE}"
"$HOME/claudecord/scripts/spawn_teammate" "$AGENT_NAME" "$WT_DIR" --model "$MODEL"

# Send task with issue context
sleep 5
"$HOME/claudecord/scripts/send_message" "$AGENT_NAME" \
  "Fix GitHub issue #${ISSUE}: ${ISSUE_TITLE}

Issue description:
${ISSUE_BODY}

Instructions:
1. Read the issue carefully and understand the problem
2. Implement the fix using GSD workflow (/gsd:fast for small fixes)
3. Run tests to verify
4. Create a PR with 'Fixes #${ISSUE}' in the body
5. Assign twaldin as reviewer on the PR
6. Post to #code-status (1485084317272244274) via claudecord_reply
7. Message LifeOS: message_lifeos 'Fix for issue #${ISSUE} complete. PR #X. Summary.'
8. /exit"

echo "Spawned $AGENT_NAME for issue #$ISSUE"
