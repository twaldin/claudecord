#!/usr/bin/env python3
"""
habit_mark — Mark one or more habits as done for today (or a specific day).

Usage:
  habit_mark <habit_name_or_alias> [<habit2> ...]
  habit_mark --all
  habit_mark --day Mon <habit>
  habit_mark --file <path> <habit>

Supports partial name matching and aliases defined in HABIT_ALIASES env var
as JSON: '{"ex": "Exercise", "r": "Read"}'
"""

import sys
import os
import re
import json
import argparse
from datetime import date
from pathlib import Path

DEFAULT_HABIT_FILE = os.path.expanduser("~/memory/habits.md")
DAYS = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]


def find_habit_file(cli_path=None):
    candidates = [
        cli_path,
        os.environ.get("HABIT_FILE"),
        DEFAULT_HABIT_FILE,
        os.path.join(os.getcwd(), "memory/habits.md"),
        os.path.join(os.getcwd(), "habits.md"),
    ]
    for p in candidates:
        if p and Path(p).exists():
            return Path(p)
    return None


def load_aliases():
    raw = os.environ.get("HABIT_ALIASES", "{}")
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return {}


def resolve_habit_name(query, known_habits, aliases):
    """Resolve a query string to a habit name. Returns matched name or None."""
    # Exact match
    if query in known_habits:
        return query
    # Alias match
    if query in aliases and aliases[query] in known_habits:
        return aliases[query]
    # Case-insensitive exact
    for h in known_habits:
        if h.lower() == query.lower():
            return h
    # Partial match (prefix)
    matches = [h for h in known_habits if h.lower().startswith(query.lower())]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        print(f"Ambiguous habit '{query}': matches {matches}", file=sys.stderr)
        return None
    return None


def mark_habit_in_file(path, habit_name, day_col):
    """Mark a habit's cell for day_col as done. Returns True if successful."""
    text = path.read_text()
    lines = text.splitlines()
    in_table = False
    header_cols = []
    col_idx = None
    result_lines = []
    marked = False

    for i, line in enumerate(lines):
        stripped = line.strip()
        if stripped.startswith("|") and "|" in stripped[1:]:
            cols_raw = stripped.split("|")
            cols = [c.strip() for c in cols_raw[1:-1]]
            if not in_table:
                header_cols = cols
                # Find the column index for day_col
                try:
                    col_idx = header_cols.index(day_col)
                except ValueError:
                    col_idx = None
                in_table = True
                result_lines.append(line)
                continue
            if set(cols[0]) <= set("-: "):
                result_lines.append(line)
                continue
            if header_cols and cols[0] == habit_name and col_idx is not None:
                # Mark this cell
                # Rebuild the row with ✅ at col_idx
                cells = cols_raw[1:-1]  # exclude leading/trailing empty from split
                while len(cells) <= col_idx:
                    cells.append("   ")
                cells[col_idx] = " ✅ "
                new_line = "|" + "|".join(cells) + "|"
                result_lines.append(new_line)
                marked = True
                continue
        else:
            in_table = False
            header_cols = []
            col_idx = None
        result_lines.append(line)

    if marked:
        path.write_text("\n".join(result_lines) + "\n")
    return marked


def get_all_habits(path):
    """Return list of habit names from the file."""
    text = path.read_text()
    lines = text.splitlines()
    habits = []
    in_table = False
    header_found = False
    for line in lines:
        stripped = line.strip()
        if stripped.startswith("|"):
            cols = [c.strip() for c in stripped.split("|")[1:-1]]
            if not header_found:
                header_found = True
                in_table = True
                continue
            if set(cols[0]) <= set("-: "):
                continue
            if in_table and cols[0]:
                habits.append(cols[0])
        else:
            if in_table:
                in_table = False
                header_found = False
    return habits


def main():
    parser = argparse.ArgumentParser(description="Mark habits as done")
    parser.add_argument("habits", nargs="*", help="Habit names or aliases to mark")
    parser.add_argument("--all", action="store_true", help="Mark all habits for today")
    parser.add_argument("--day", help="Day to mark (Mon/Tue/etc), default: today")
    parser.add_argument("--file", help="Path to habit tracker file")
    args = parser.parse_args()

    habit_file = find_habit_file(args.file)
    if not habit_file:
        print(f"ERROR: No habit file found. Set HABIT_FILE or create {DEFAULT_HABIT_FILE}", file=sys.stderr)
        sys.exit(1)

    day_col = args.day if args.day else DAYS[date.today().weekday()]
    if day_col not in DAYS:
        print(f"ERROR: Invalid day '{day_col}'. Use: {', '.join(DAYS)}", file=sys.stderr)
        sys.exit(1)

    aliases = load_aliases()
    known_habits = get_all_habits(habit_file)

    targets = known_habits if args.all else args.habits

    if not targets:
        print("No habits specified. Use --all or provide habit names.", file=sys.stderr)
        sys.exit(1)

    for query in targets:
        resolved = resolve_habit_name(query, known_habits, aliases) if not args.all else query
        if resolved is None:
            print(f"WARNING: Habit '{query}' not found in {habit_file}", file=sys.stderr)
            continue
        success = mark_habit_in_file(habit_file, resolved, day_col)
        if success:
            print(f"✅ Marked: {resolved} ({day_col})")
        else:
            print(f"WARNING: Could not mark '{resolved}' — check file format", file=sys.stderr)


if __name__ == "__main__":
    main()
