#!/usr/bin/env python3
"""
habit_new_week — Append a new week section to the habit tracker.

Usage: habit_new_week [--file <path>] [--dry-run]

Creates a new "## Week of YYYY-MM-DD" section with today's week start (Monday)
and an empty table matching the previous week's habit list.
"""

import sys
import os
import argparse
import re
from datetime import date, timedelta
from pathlib import Path

DEFAULT_HABIT_FILE = os.path.expanduser("~/memory/habits.md")
DAYS = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]


def find_habit_file(cli_path=None):
    candidates = [
        cli_path,
        os.environ.get("HABIT_FILE"),
        DEFAULT_HABIT_FILE,
        os.path.join(os.getcwd(), "memory/habits.md"),
        os.path.join(os.getcwd(), "habits.md"),
    ]
    for p in candidates:
        if p and Path(p).exists():
            return Path(p)
    return None


def get_week_start():
    """Return Monday of the current week."""
    today = date.today()
    return today - timedelta(days=today.weekday())


def extract_habit_names(text):
    """Extract habit names from the most recent week's table."""
    lines = text.splitlines()
    habits = []
    in_table = False
    header_found = False
    for line in lines:
        stripped = line.strip()
        if stripped.startswith("|"):
            cols = [c.strip() for c in stripped.split("|")[1:-1]]
            if not header_found:
                header_found = True
                in_table = True
                continue
            if set(cols[0]) <= set("-: "):
                continue
            if in_table and cols[0]:
                habits.append(cols[0])
        else:
            if in_table:
                in_table = False
                header_found = False
    return habits


def build_week_section(week_start, habits):
    """Build markdown for a new week section."""
    date_str = week_start.strftime("%Y-%m-%d")
    header = f"## Week of {date_str}"
    col_header = "| Habit | " + " | ".join(DAYS) + " |"
    separator = "|-------|" + "------|" * len(DAYS)
    rows = [f"| {h} | " + " | ".join(["   "] * len(DAYS)) + " |" for h in habits]
    return "\n".join([header, col_header, separator] + rows) + "\n"


def check_week_exists(text, week_start):
    return f"Week of {week_start.strftime('%Y-%m-%d')}" in text


def main():
    parser = argparse.ArgumentParser(description="Create new habit tracker week")
    parser.add_argument("--file", help="Path to habit tracker file")
    parser.add_argument("--dry-run", action="store_true", help="Print what would be added, don't write")
    args = parser.parse_args()

    habit_file = find_habit_file(args.file)

    week_start = get_week_start()

    if habit_file and habit_file.exists():
        text = habit_file.read_text()
        if check_week_exists(text, week_start):
            print(f"Week of {week_start} already exists in {habit_file}")
            sys.exit(0)
        habits = extract_habit_names(text)
    else:
        # New file
        habits = []
        text = ""
        if not habit_file:
            habit_file = Path(DEFAULT_HABIT_FILE)
            habit_file.parent.mkdir(parents=True, exist_ok=True)

    if not habits:
        print("No existing habits found. Add habit names manually or seed the file first.")
        print("Example row to add: | Exercise | | | | | | | |")

    new_section = build_week_section(week_start, habits)

    if args.dry_run:
        print("Would append:\n")
        print(new_section)
        return

    with open(habit_file, "a") as f:
        if text and not text.endswith("\n\n"):
            f.write("\n")
        f.write(new_section)

    print(f"Added week of {week_start} to {habit_file}")
    if habits:
        print(f"Habits: {', '.join(habits)}")


if __name__ == "__main__":
    main()
