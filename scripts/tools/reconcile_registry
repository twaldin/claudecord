#!/bin/bash
# reconcile_registry — Sync registry with actual tmux state
#
# Run at session boot to find agents that survived compaction
# or detect stale entries that reference dead windows.
#
# Usage: reconcile_registry [--fix] [--adopt] [--cleanup]
#   Without flags: report only (dry run)
#   --fix:     update registry entries to match reality
#   --adopt:   register unrecognized tmux windows with the daemon
#   --cleanup: call POST /agent/died for agents with orphaned channels

SESSION="claudecord"
REGISTRY="$HOME/claudecord/registry.tsv"
DAEMON_URL="${CLAUDECORD_DAEMON_URL:-http://localhost:19532}"

FIX=""
ADOPT=""
CLEANUP=""
for arg in "$@"; do
  case "$arg" in
    --fix)     FIX="--fix" ;;
    --adopt)   ADOPT="--adopt" ;;
    --cleanup) CLEANUP="--cleanup" ;;
  esac
done

daemon_curl() {
  if [ -n "$CLAUDECORD_API_SECRET" ]; then
    curl -sf -H "Authorization: Bearer $CLAUDECORD_API_SECRET" "$@"
  else
    curl -sf "$@"
  fi
}

if [ ! -f "$REGISTRY" ]; then
  echo "No registry at $REGISTRY"
  exit 1
fi

if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "No tmux session '$SESSION'"
  exit 1
fi

echo "=== Registry Reconciliation ==="
echo ""

CHANGES=0

# Check each registry entry against reality
while IFS='|' read -r name status dir spawned; do
  [[ "$name" == \#* ]] && continue
  [ -z "$name" ] && continue

  if [ "$status" = "alive" ]; then
    # Check if window exists
    if ! tmux list-windows -t "$SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^$name$"; then
      echo "STALE: $name registered as alive but window is gone"
      if [ "$FIX" = "--fix" ]; then
        sed -i '' "s/^$name|alive|/$name|dead|/" "$REGISTRY"
        echo "  → marked dead"
      fi
      CHANGES=$((CHANGES + 1))
    else
      # Check if claude is running
      PANE_PID=$(tmux display-message -t "$SESSION:$name" -p '#{pane_pid}' 2>/dev/null)
      if [ -n "$PANE_PID" ] && pgrep -P "$PANE_PID" -f "claude" >/dev/null 2>&1; then
        echo "OK: $name alive in window $name (claude running)"
      else
        echo "EXITED: $name — window exists but claude not running"
        CHANGES=$((CHANGES + 1))
      fi
    fi
  fi
done < "$REGISTRY"

# Scan for unregistered claude agents in tmux windows
echo ""
echo "--- Scanning for unregistered agents ---"
while IFS=' ' read -r win_name win_index; do
  [ -z "$win_name" ] && continue
  PANE_PID=$(tmux display-message -t "$SESSION:$win_name" -p '#{pane_pid}' 2>/dev/null)
  if [ -n "$PANE_PID" ] && pgrep -P "$PANE_PID" -f "claude" >/dev/null 2>&1; then
    # Check if registered
    if ! grep -q "^$win_name|alive|" "$REGISTRY" 2>/dev/null; then
      echo "UNREGISTERED: claude running in window '$win_name'"
      if [ "$ADOPT" = "--adopt" ]; then
        daemon_curl -X POST "$DAEMON_URL/agent/spawn" \
          -H 'Content-Type: application/json' \
          -d "{\"agentName\":\"$win_name\",\"agentType\":\"coder\",\"lifecycle\":\"ephemeral\",\"task\":\"adopted by reconcile\"}" || true
        echo "  → adopted $win_name"
      fi
      CHANGES=$((CHANGES + 1))
    fi
  fi
done < <(tmux list-windows -t "$SESSION" -F '#{window_name} #{window_index}' 2>/dev/null)

# Auto-prune dead entries
DEAD_COUNT=$(grep -c '|dead|' "$REGISTRY" 2>/dev/null || echo 0)
if [ "$DEAD_COUNT" -gt 0 ]; then
  grep -v '|dead|' "$REGISTRY" > "${REGISTRY}.tmp"
  mv "${REGISTRY}.tmp" "$REGISTRY"
  echo "Pruned $DEAD_COUNT dead entries."
fi

# Check for orphaned Discord channels via GET /agents
echo ""
echo "--- Checking for orphaned Discord channels ---"
AGENTS_JSON=$(daemon_curl "$DAEMON_URL/agents" 2>/dev/null || true)
if [ -z "$AGENTS_JSON" ]; then
  echo "WARNING: daemon unreachable at $DAEMON_URL — skipping orphaned channel check"
else
  # Find dead agents that still have a channelId (orphaned channels)
  # Requires jq; skip gracefully if not available
  if command -v jq >/dev/null 2>&1; then
    ORPHANED=$(echo "$AGENTS_JSON" | jq -r '.agents[] | select(.status == "dead" and .channelId != null) | .name' 2>/dev/null || true)
    if [ -z "$ORPHANED" ]; then
      echo "No orphaned channels found."
    else
      while IFS= read -r agent_name; do
        CHANNEL_ID=$(echo "$AGENTS_JSON" | jq -r ".agents[] | select(.name == \"$agent_name\") | .channelId")
        echo "ORPHANED CHANNEL: $agent_name (channelId: $CHANNEL_ID) — agent dead but channel not archived"
        if [ "$CLEANUP" = "--cleanup" ]; then
          daemon_curl -X POST "$DAEMON_URL/agent/died" \
            -H 'Content-Type: application/json' \
            -d "{\"agentName\":\"$agent_name\"}" || true
          echo "  → triggered archival for $agent_name"
        fi
        CHANGES=$((CHANGES + 1))
      done <<< "$ORPHANED"
    fi
  else
    echo "WARNING: jq not installed — skipping orphaned channel check"
  fi
fi

echo ""
if [ $CHANGES -eq 0 ]; then
  echo "Registry is clean — no discrepancies."
else
  echo "$CHANGES discrepancies found."
  [ "$FIX" != "--fix" ] && [ "$ADOPT" != "--adopt" ] && [ "$CLEANUP" != "--cleanup" ] && \
    echo "Run with --fix / --adopt / --cleanup to remediate."
fi
