#!/usr/bin/env python3
"""
token_guard — Check context age and write a warning file if compaction is needed.

Usage: token_guard [--state-dir <dir>] [--max-age-hours <n>] [--dry-run]

Checks:
1. Age of the current session (based on WORKING.md mtime or a session start file)
2. If older than --max-age-hours (default: 4), writes a 'token_warning' file

The orchestrator checks for this file on heartbeat and compacts if it exists.
This file is deleted after compaction completes (when WORKING.md is updated).

Exit codes:
  0 — no warning
  1 — warning written (compact recommended)
  2 — error
"""

import sys
import os
import argparse
from datetime import datetime, timedelta
from pathlib import Path

DEFAULT_STATE_DIR = os.environ.get("CLAUDECORD_STATE_DIR",
    os.path.join(os.getcwd(), "agents/orchestrator"))
DEFAULT_MAX_AGE_HOURS = 4
TOKEN_WARNING_FILE = "token_warning"
SESSION_START_FILE = ".session_start"


def get_session_age(state_dir):
    """Return session age in hours. Uses .session_start if it exists, else WORKING.md mtime."""
    state_path = Path(state_dir)

    session_start_file = state_path / SESSION_START_FILE
    if session_start_file.exists():
        mtime = datetime.fromtimestamp(session_start_file.stat().st_mtime)
        return (datetime.now() - mtime).total_seconds() / 3600

    working_md = state_path / "memory" / "WORKING.md"
    if working_md.exists():
        mtime = datetime.fromtimestamp(working_md.stat().st_mtime)
        return (datetime.now() - mtime).total_seconds() / 3600

    # Can't determine — no files to check
    return 0


def mark_session_start(state_dir):
    """Create or touch the session start file."""
    p = Path(state_dir) / SESSION_START_FILE
    p.touch()


def clear_token_warning(state_dir):
    """Remove token warning file (called after successful compaction)."""
    p = Path(state_dir) / TOKEN_WARNING_FILE
    if p.exists():
        p.unlink()


def main():
    parser = argparse.ArgumentParser(description="Check context age and warn if compaction needed")
    parser.add_argument("--state-dir", default=DEFAULT_STATE_DIR,
                       help="Directory containing orchestrator state files")
    parser.add_argument("--max-age-hours", type=float, default=DEFAULT_MAX_AGE_HOURS,
                       help="Max session age in hours before warning (default: 4)")
    parser.add_argument("--dry-run", action="store_true",
                       help="Report status without writing files")
    parser.add_argument("--mark-start", action="store_true",
                       help="Record session start time (call on orchestrator startup)")
    parser.add_argument("--clear", action="store_true",
                       help="Clear the warning file (call after successful compaction)")
    args = parser.parse_args()

    state_dir = Path(args.state_dir)
    if not state_dir.exists():
        print(f"ERROR: State directory not found: {state_dir}", file=sys.stderr)
        sys.exit(2)

    if args.mark_start:
        if not args.dry_run:
            mark_session_start(state_dir)
        print(f"Session start recorded in {state_dir}")
        sys.exit(0)

    if args.clear:
        if not args.dry_run:
            clear_token_warning(state_dir)
        print("Token warning cleared")
        sys.exit(0)

    age_hours = get_session_age(state_dir)
    warning_file = state_dir / TOKEN_WARNING_FILE

    if age_hours >= args.max_age_hours:
        if not args.dry_run:
            warning_file.write_text(
                f"Context age: {age_hours:.1f}h (threshold: {args.max_age_hours}h)\n"
                f"Written: {datetime.now().isoformat()}\n"
                f"Action: orchestrator should compact at next natural break\n"
            )
        print(f"WARNING: Context age {age_hours:.1f}h >= {args.max_age_hours}h threshold. "
              f"{'(dry-run, not written)' if args.dry_run else 'Token warning file written.'}")
        sys.exit(1)
    else:
        remaining = args.max_age_hours - age_hours
        print(f"OK: Context age {age_hours:.1f}h. {remaining:.1f}h until warning threshold.")
        # Clean up stale warning file if it exists
        if warning_file.exists() and not args.dry_run:
            warning_file.unlink()
        sys.exit(0)


if __name__ == "__main__":
    main()
