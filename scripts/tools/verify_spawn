#!/bin/bash
# verify_spawn — Verify an agent spawned successfully
#
# Checks within 10 seconds that:
#   1. Agent has a tmux window
#   2. Claude process is running in it
#   3. Agent registered with daemon (GET /agents)
#   4. Discord channel was created (if not persistent)
#
# Usage: verify_spawn <name> [--timeout <seconds>]
#
# Returns exit code 0 if all checks pass, 1 if any fail.
# Prints a report either way.

set -e

CLAUDECORD_HOME="${CLAUDECORD_HOME:-$HOME/claudecord}"
if [ -f "$CLAUDECORD_HOME/.env" ]; then
  set -a; source "$CLAUDECORD_HOME/.env"; set +a
fi

NAME="$1"
SESSION="${CLAUDECORD_SESSION:-claudecord}"
TIMEOUT=10

if [ -z "$NAME" ]; then
  echo "Usage: verify_spawn <name> [--timeout <seconds>]"
  exit 1
fi

# Parse optional timeout
if [ "$2" = "--timeout" ] && [ -n "$3" ]; then
  TIMEOUT="$3"
fi

DAEMON_URL="${CLAUDECORD_DAEMON_URL:-http://localhost:19532}"
AUTH_HEADER=""
if [ -n "$CLAUDECORD_API_SECRET" ]; then
  AUTH_HEADER="-H \"Authorization: Bearer $CLAUDECORD_API_SECRET\""
fi

PASS=0
FAIL=0

check() {
  local label="$1"
  local result="$2"
  if [ "$result" = "ok" ]; then
    echo "  [PASS] $label"
    PASS=$((PASS + 1))
  else
    echo "  [FAIL] $label — $result"
    FAIL=$((FAIL + 1))
  fi
}

echo "=== Verifying spawn: $NAME (timeout: ${TIMEOUT}s) ==="
echo ""

# Wait for agent to initialize
ELAPSED=0
WINDOW_OK=false
CLAUDE_OK=false
REGISTERED=false

while [ $ELAPSED -lt $TIMEOUT ]; do
  # Check 1: tmux window exists
  if tmux list-windows -t "$SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${NAME}$"; then
    WINDOW_OK=true

    # Check 2: Claude running in window
    PANE_PID=$(tmux display-message -t "$SESSION:$NAME" -p '#{pane_pid}' 2>/dev/null)
    if [ -n "$PANE_PID" ] && pgrep -P "$PANE_PID" -f "claude" >/dev/null 2>&1; then
      CLAUDE_OK=true
    fi
  fi

  # Check 3: Agent registered with daemon
  if [ "$REGISTERED" = "false" ]; then
    AGENTS_RESPONSE=$(curl -sf "$DAEMON_URL/agents" \
      ${CLAUDECORD_API_SECRET:+-H "Authorization: Bearer $CLAUDECORD_API_SECRET"} \
      2>/dev/null || echo '{"agents":[]}')
    if echo "$AGENTS_RESPONSE" | grep -q "\"name\":\"$NAME\""; then
      REGISTERED=true
    fi
  fi

  # If all core checks pass, stop waiting
  if [ "$WINDOW_OK" = "true" ] && [ "$CLAUDE_OK" = "true" ] && [ "$REGISTERED" = "true" ]; then
    break
  fi

  sleep 1
  ELAPSED=$((ELAPSED + 1))
done

# Report
check "Tmux window exists" "$([ "$WINDOW_OK" = "true" ] && echo "ok" || echo "window '$NAME' not found in session '$SESSION'")"
check "Claude process running" "$([ "$CLAUDE_OK" = "true" ] && echo "ok" || echo "no claude process in window")"
check "Registered with daemon" "$([ "$REGISTERED" = "true" ] && echo "ok" || echo "agent not in GET /agents after ${TIMEOUT}s")"

# Check 4: Channel created (only for non-persistent)
if [ "$REGISTERED" = "true" ]; then
  CHANNEL_ID=$(echo "$AGENTS_RESPONSE" | grep -o "\"name\":\"$NAME\"[^}]*\"channelId\":\"[^\"]*\"" | grep -o '"channelId":"[^"]*"' | cut -d'"' -f4 2>/dev/null || true)
  if [ -n "$CHANNEL_ID" ] && [ "$CHANNEL_ID" != "null" ]; then
    check "Discord channel created" "ok"
  else
    check "Discord channel created" "no channelId (may be persistent agent or daemon has no guild)"
  fi
fi

echo ""
echo "$PASS passed, $FAIL failed"

if [ $FAIL -gt 0 ]; then
  exit 1
fi
