#!/usr/bin/env bash
# compact — Send /clear to the orchestrator's tmux pane to compact context.
#
# Usage: compact [--session <name>] [--pane <id>]
#
# Defaults:
#   session: claudecord
#   pane: 0 (orchestrator)
#
# The orchestrator calls this with run_in_background: true after updating
# all state files and deleting crons. Do not call this until state is saved.

set -euo pipefail

SESSION="${CLAUDECORD_SESSION:-claudecord}"
PANE="${CLAUDECORD_PANE:-0}"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --session) SESSION="$2"; shift 2 ;;
        --pane)    PANE="$2";    shift 2 ;;
        *) echo "Unknown argument: $1" >&2; exit 1 ;;
    esac
done

TARGET="${SESSION}:${PANE}"

# Check the session exists
if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "ERROR: tmux session '$SESSION' not found" >&2
    exit 1
fi

# Brief pause to let any final tool calls settle
sleep 1

# Send /clear to the pane
tmux send-keys -t "$TARGET" "/clear" Enter

echo "Sent /clear to ${TARGET}"
