#!/usr/bin/env python3
"""
habit_check — Read habit tracker and report current status.

Usage: habit_check [--json] [--file <path>]

Reads the habit tracker markdown file and reports:
- Each habit and its streak
- Whether each habit was marked today
- Any habits not marked in >2 days (flagged as stale)

Habit file format expected:
## Week of YYYY-MM-DD
| Habit | Mon | Tue | Wed | Thu | Fri | Sat | Sun |
|-------|-----|-----|-----|-----|-----|-----|-----|
| Exercise | ✅ | ✅ | | | | | |
| Read | ✅ | | ✅ | | | | |
"""

import sys
import os
import json
import argparse
from datetime import date, timedelta
from pathlib import Path

DEFAULT_HABIT_FILE = os.path.expanduser("~/memory/habits.md")

DAYS = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
DONE_MARKERS = {"✅", "x", "X", "done", "yes", "1", "✓"}


def find_habit_file(cli_path=None):
    candidates = [
        cli_path,
        os.environ.get("HABIT_FILE"),
        DEFAULT_HABIT_FILE,
        os.path.join(os.getcwd(), "memory/habits.md"),
        os.path.join(os.getcwd(), "habits.md"),
    ]
    for p in candidates:
        if p and Path(p).exists():
            return Path(p)
    return None


def parse_habit_file(path):
    """Parse markdown habit table. Returns dict: {habit_name: {day_name: bool}}."""
    text = path.read_text()
    lines = text.splitlines()
    habits = {}
    in_table = False
    header_cols = []

    for line in lines:
        line = line.strip()
        if not line:
            continue
        if line.startswith("|") and "|" in line[1:]:
            cols = [c.strip() for c in line.split("|")[1:-1]]
            if not in_table:
                # First table row = header
                header_cols = cols
                in_table = True
                continue
            if set(cols[0]) <= set("-: "):
                # Separator row
                continue
            if header_cols:
                habit_name = cols[0]
                habits[habit_name] = {}
                for i, day in enumerate(header_cols[1:], start=1):
                    if i < len(cols):
                        cell = cols[i].strip()
                        habits[habit_name][day] = cell in DONE_MARKERS
                    else:
                        habits[habit_name][day] = False
        else:
            in_table = False
            header_cols = []

    return habits


def get_today_col():
    """Return the day-of-week column name for today."""
    return DAYS[date.today().weekday()]


def streak_count(day_map):
    """Count consecutive days marked from today backwards."""
    today_idx = date.today().weekday()
    streak = 0
    for i in range(today_idx, -1, -1):
        if day_map.get(DAYS[i], False):
            streak += 1
        else:
            break
    return streak


def days_since_marked(day_map):
    """How many days ago was this habit last marked (within the current week)."""
    today_idx = date.today().weekday()
    for i in range(today_idx, -1, -1):
        if day_map.get(DAYS[i], False):
            return today_idx - i
    return today_idx + 1  # Not marked at all this week


def main():
    parser = argparse.ArgumentParser(description="Check habit tracker status")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--file", help="Path to habit tracker file")
    args = parser.parse_args()

    habit_file = find_habit_file(args.file)
    if not habit_file:
        msg = f"No habit file found. Set HABIT_FILE env var or create {DEFAULT_HABIT_FILE}"
        if args.json:
            print(json.dumps({"error": msg}))
        else:
            print(f"ERROR: {msg}", file=sys.stderr)
        sys.exit(1)

    habits = parse_habit_file(habit_file)
    today_col = get_today_col()

    results = []
    stale = []
    for name, day_map in habits.items():
        marked_today = day_map.get(today_col, False)
        streak = streak_count(day_map)
        days_ago = days_since_marked(day_map)
        is_stale = days_ago > 2

        results.append({
            "habit": name,
            "marked_today": marked_today,
            "streak": streak,
            "days_since_marked": days_ago,
            "stale": is_stale,
        })
        if is_stale:
            stale.append(name)

    if args.json:
        print(json.dumps({"habits": results, "stale": stale, "today": today_col}))
        return

    print(f"Habit Status — {date.today().strftime('%A, %Y-%m-%d')}")
    print()
    for r in results:
        status = "✅" if r["marked_today"] else "⬜"
        stale_flag = " ⚠️ STALE" if r["stale"] else ""
        print(f"  {status} {r['habit']}  (streak: {r['streak']} days){stale_flag}")

    if stale:
        print()
        print(f"Stale habits (not marked in >2 days): {', '.join(stale)}")


if __name__ == "__main__":
    main()
